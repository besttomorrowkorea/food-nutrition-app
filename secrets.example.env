# NutriSync — 필요한 시크릿 목록
# 이 파일을 복사해서 실제 값을 채우세요. 절대 Git에 커밋하지 마세요.
# cp secrets.example.env .env

# ─────────────────────────────────────────
# Firebase Cloud Functions 시크릿
# Firebase Console → Secret Manager에 등록
# ─────────────────────────────────────────

# Claude API 키 (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# (선택) Stripe 시크릿 키 — Phase 3 보충제 결제용
# STRIPE_SECRET_KEY=sk_test_...

# ─────────────────────────────────────────
# Flutter 앱 빌드 변수 (--dart-define으로 전달)
# ─────────────────────────────────────────

# RevenueCat API 키 (https://app.revenuecat.com) — Phase 2
# Android: RC_API_KEY_ANDROID=appl_xxx
# iOS:     RC_API_KEY_IOS=appl_xxx

# Stripe 공개 키 (앱에 포함 가능)
# STRIPE_PK=pk_test_...

# ─────────────────────────────────────────
# Firebase 설정 파일 (Git에서 제외됨)
# ─────────────────────────────────────────

# android/app/google-services.json     — Firebase Console에서 다운로드
# ios/Runner/GoogleService-Info.plist  — Firebase Console에서 다운로드

# ─────────────────────────────────────────
# 로컬 개발 설정
# ─────────────────────────────────────────

# Firebase 에뮬레이터 사용 시:
# flutter run --dart-define=USE_EMULATOR=true

# Firebase 시크릿 등록 명령어 (처음 한 번):
# firebase functions:secrets:set ANTHROPIC_API_KEY
